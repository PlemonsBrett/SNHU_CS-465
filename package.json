{
  "name": "snhu_cs-370",
  "version": "1.0.0",
  "description": "Full-stack web application for SNHU CS-465 course",
  "type": "module",
  "private": true,
  "workspaces": {
    "packages": ["server", "client", "packages/*"]
  },
  "scripts": {
    "ci:publish": "pnpm publish -r",
    "start:server": "cd server && pnpm run dev",
    "build:server": "cd server && pnpm run build",
    "test": "pnpm -r test",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "biome format .",
    "format:fix": "biome format . --write",
    "prepare": "node .husky/install.mjs",
    "commit": "commit"
  },
  "keywords": ["typescript", "express", "handlebars", "monorepo"],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.5.2",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.29.3",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/types": "^19.8.1",
    "@types/jest": "^29.5.14",
    "conventional-changelog-atom": "^5.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild"]
  }
}
